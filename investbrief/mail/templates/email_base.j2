<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>{{base_css}}</style>
</head>
<body>
  <div class="container">
    <div class="masthead">
      <div class="masthead-brand">MACRO BRIEF</div>
      <h1 class="masthead-title">{{title}}</h1>
      <div class="masthead-date">{{date}} · {{data_time_label}} {{data_time}}</div>
    </div>

    <!-- ① 核心观点 -->
    <div class="section">
      <div class="section-head">
        <span class="kicker">CORE VIEW</span>
        <h2 class="section-title">核心观点</h2>
      </div>
      <div class="summary-box">{{macro_summary}}</div>
    </div>

    <!-- Market Sections (外围 + A股 + 黄金，动态插入) -->
    {{market_sections}}

    <!-- 卖方机构观点 -->
    {{research_views}}

    <!-- 风险提示与下周关注 -->
    <div class="section">
      <div class="section-head">
        <span class="kicker">RISK &amp; NEXT WEEK</span>
        <h2 class="section-title">风险提示与下周关注</h2>
      </div>
      <div class="summary-box">{{risk_outlook}}</div>
    </div>

    <!-- 重要新闻 -->
    <div class="section">
      <div class="section-head">
        <span class="kicker">HEADLINES</span>
        <h2 class="section-title">{{global_news_title}}</h2>
      </div>
      {{global_news}}
    </div>

    <div class="footer">
      {{disclaimer}}<br>
      {{generated_by}} · {{generated_at}}
    </div>
  </div>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>{{media_css}}</style>
</head>
<body>
  <div class="container">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="width:100%;">
      <tr><td class="masthead" bgcolor="#1a1f2e">
        <div class="masthead-brand">PORTFOLIO BRIEF</div>
        <h1 class="masthead-title">{{title}}</h1>
        <div class="masthead-date">{{date}} · {{data_time_label}} {{data_time}}</div>
      </td></tr>
    </table>

    <!-- 持仓组合研判（Claude） -->
    <div class="section">
      <div class="section-head">
        <span class="kicker">PORTFOLIO VIEW</span>
        <h2 class="section-title">持仓组合研判</h2>
      </div>
      <div class="summary-box">{{holdings_summary}}</div>
    </div>

    <!-- 持仓标的卡片 -->
    <div class="section">
      <div class="section-head">
        <span class="kicker">HOLDINGS</span>
        <h2 class="section-title">标的明细</h2>
      </div>
      {{holdings_sections}}
    </div>

    <div class="footer">
      {{disclaimer}}<br>
      {{generated_by}} · {{generated_at}}
    </div>
  </div>
</body>
</html>

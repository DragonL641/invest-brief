# API Keys
FINNHUB_KEY=
ALPHAVANTAGE_KEY=
TAVILY_KEY=

# SMTP
SMTP_PASSWORD=

# Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
# Override default Sonnet model. The value is used as-is by core/llm.py:default_model(),
# EXCEPT a trailing context marker like "[1m]" is stripped — Claude Code's runtime leaks
# IDs such as "glm-5.2[1m]" that GLM-style Anthropic-compatible endpoints reject.
# Hardcoded fallback: claude-sonnet-4-5-20250929 (claude-sonnet-4-6 is not recognized by those endpoints).
ANTHROPIC_DEFAULT_SONNET_MODEL=
# Alternative: ANTHROPIC_AUTH_TOKEN auto-aliases to ANTHROPIC_API_KEY
ANTHROPIC_AUTH_TOKEN=

# SQLite path (override for Docker volume mounts / non-default locations).
# Defaults to data/macro_data.db when unset. See investbrief/core/config.py.
INVESTBRIEF_DB_PATH=
